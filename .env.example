# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENAI_API_KEY: Optional. Used if OpenAI models are deployed for SHANA Analysis.
OPENAI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SMTP Settings for sending real sign-up, login, and password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
RESEND_API_KEY=

# SHANA Key Vault Encryption Key
SHANA_ENCRYPTION_KEY=

# Google OAuth Credentials for Calendar Connector
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe Secret API Key for authentic card checkouts
STRIPE_SECRET_KEY=""

# Configurable Rate Limits for security hardening
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_AI_WINDOW_MS=60000
RATE_LIMIT_AI_MAX=10
RATE_LIMIT_UPLOADS_WINDOW_MS=300000
RATE_LIMIT_UPLOADS_MAX=15
RATE_LIMIT_REPORTS_WINDOW_MS=600000
RATE_LIMIT_REPORTS_MAX=5
RATE_LIMIT_RESET_WINDOW_MS=1800000
RATE_LIMIT_RESET_MAX=3
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT_MAX=100
